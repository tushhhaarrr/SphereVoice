# SphereVoice — Local Development Environment Variables
# Copy this file to .env and fill in your values
# See backend/app/core/config.py for all available settings

# ── Application ──────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
BACKEND_PUBLIC_URL=http://localhost:2998
CORS_ORIGINS=["http://localhost:2999"]

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/SphereVoice_dev

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── Encryption (AES-256 — base64-encoded 32 bytes) ──────
ENCRYPTION_KEY=P6gGu9G+7eecCoLsQhLj3u+YZNN6zrfHj96dJLh0qwo=

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_BACKEND=redis
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Sentry (optional) ───────────────────────────────────
SENTRY_DSN=

# ── OpenTelemetry (optional) ────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=SphereVoice-backend

# ── Azure Blob Storage ──────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_RECORDINGS=SphereVoice-recordings
AZURE_STORAGE_CONTAINER_KB_FILES=SphereVoice-kb-files

# ── LiveKit ──────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_DOMAIN=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ── Default Provider Keys (platform-level fallbacks) ────
# STT
DEEPGRAM_API_KEY=
SONIOX_API_KEY=
# LLM
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
# TTS
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
INWORLD_API_KEY=
SARVAM_API_KEY=
SMALLEST_API_KEY=

# ── Azure OpenAI (optional — used when provider=azure_openai) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-5.3-chat
AZURE_OPENAI_AGENT_DEPLOYMENT=gpt-5.3-chat
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small-2
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=

# ── Telephony — Plivo (primary) ─────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_TEST_NUMBER=
PLIVO_ZENTRUNK_TERMINATION_DOMAIN=
PLIVO_ZENTRUNK_SIP_USERNAME=
PLIVO_ZENTRUNK_SIP_PASSWORD=
PLIVO_OUTBOUND_NUMBERS=

# ── Telephony — Twilio (optional) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SIP_DOMAIN=

# ── Telephony — Vobiz (optional) ────────────────────────
VOBIZ_AUTH_ID=
VOBIZ_API_KEY=

# ── Firecrawl (website KB seeding) ──────────────────────
FIRECRAWL_API_KEY=

# ── Zoho CRM Integration ────────────────────────────────
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REDIRECT_URI=http://localhost:2998/api/v1/integrations/crm/zoho/callback
ZOHO_CRM_DATA_CENTER=in

# ── HubSpot CRM Integration ─────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:2998/api/v1/integrations/crm/hubspot/callback

# ── Salesforce CRM Integration ──────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:2998/api/v1/integrations/crm/salesforce/callback

# ── Google Integration (Calendar + Sheets) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:2998/api/v1/integrations/google/calendar/callback
GOOGLE_SHEETS_REDIRECT_URI=http://localhost:2998/api/v1/integrations/google/sheets/callback

# ── Calendly Integration ────────────────────────────────
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=http://localhost:2998/api/v1/integrations/calendly/callback
CALENDLY_WEBHOOK_SIGNING_KEY=

# ── WhatsApp (Meta Cloud API) ───────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── SendGrid (optional) ─────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_DEFAULT_FROM_EMAIL=

# ── Email (SMTP relay) ──────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=re_your_resend_api_key_here
SMTP_USE_TLS=true
SMTP_START_TLS=false
EMAIL_FROM_ADDRESS=noreply@oss.Sphere.ai
EMAIL_FROM_NAME=SphereVoice

# ── Frontend URL (used in invite links) ─────────────────
FRONTEND_URL=http://localhost:2999

# ── Frontend (set in frontend/.env.local, not here) ─────
# NEXT_PUBLIC_API_URL=http://localhost:2998
