          "id": "extractFields",
          "options": { "source": "labels", "replace": false }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "tsNs": true, "labels": true },
            "indexByName": {}
          }
        }
      ],
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | level=~\"error|critical\" | call_id != \"\"",
          "legendFormat": "",
          "refId": "A"
        }
