{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "← Operations Overview",
      "tooltip": "Back to main dashboard",
      "type": "link",
      "url": "/d/SphereVoice-operations-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔴 Recent Failed Calls (click a call_id to drill in)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "error": { "color": "red", "text": "ERROR" } } },
                  { "type": "value", "options": { "critical": { "color": "dark-red", "text": "CRITICAL" } } },
                  { "type": "value", "options": { "warning": { "color": "orange", "text": "WARNING" } } },
                  { "type": "value", "options": { "info": { "color": "green", "text": "INFO" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "call_id" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Drill into this call",
                    "url": "/d/SphereVoice-call-debugger?var-call_id=${__value.raw}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "blue" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "title": "Failed Calls & Errors (red = error, orange = warning)",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "tsNs": true, "labels": true },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | level=~\"error|critical|warning\" | call_id != \"\" | line_format \"{{.call_id}} {{.event}} {{.level}}\"",
          "legendFormat": "",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 200,
      "title": "📞 Call Timeline for: $call_id",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 10,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      },
      "title": "Call Lifecycle Events (chronological)",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | call_id=`$call_id` | event=~\"call_started|call_record_created|pipeline_started|call_ended|call_failed|pipeline_failed|call_participant_joined|call_participant_left\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "🔴 Errors for Call: $call_id",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "displayMode": "color-background-solid"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Line" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "dark-red" }
              },
              {
                "id": "custom.width",
                "value": 800
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "error": { "color": "red", "text": "🔴 ERROR" } } },
                  { "type": "value", "options": { "critical": { "color": "dark-red", "text": "🔴 CRITICAL" } } },
                  { "type": "value", "options": { "warning": { "color": "orange", "text": "🟡 WARNING" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 20,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "title": "⚠️ Errors & Warnings for This Call (RED background = errors)",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "tsNs": true, "labels": true },
            "indexByName": {}
          }
        }
      ],
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | call_id=`$call_id` | level=~\"error|critical|warning\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "id": 21,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "🔴 Error Logs (detailed, click to expand)",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | call_id=`$call_id` | level=~\"error|critical|warning\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 400,
      "title": "📋 Full Call Log (all levels)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 40 },
      "id": 30,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      },
      "title": "Complete Call Log (all events, chronological)",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | call_id=`$call_id`",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 500,
      "title": "🔗 Distributed Traces for: $call_id",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trace_id" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Trace in Tempo",
                    "url": "/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D",
                    "targetBlank": true
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "purple" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 55 },
      "id": 40,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "title": "Trace IDs (click purple ID to open in Tempo)",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "tsNs": true, "labels": true, "Line": true },
            "indexByName": {}
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "trace_id": { "operation": "groupby", "aggregations": [] }
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | call_id=`$call_id` | trace_id != \"\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["SphereVoice", "debugging", "calls"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Call ID",
        "name": "call_id",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox",
        "description": "Paste a call UUID to see all logs, errors, and traces for that call"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({service=\"backend\"}, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant_id",
        "options": [],
        "query": { "query": "label_values({service=\"backend\"}, tenant_id)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SphereVoice Call Debugger",
  "uid": "SphereVoice-call-debugger",
  "version": 1
}
