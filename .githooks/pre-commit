#!/usr/bin/env bash
# Prevent accidental commit of secrets and env files
set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

# 1. Block .env files from being committed
BLOCKED_PATTERNS=(
  '\.env$'
  '\.env\.'
  '\.pem$'
  '\.key$'
  '\.tfvars$'
  '\.tfstate'
  'id_rsa'
  'id_ed25519'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for file in $STAGED_FILES; do
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}BLOCKED:${NC} '$file' matches blocked pattern '$pattern'"
      echo "If intentional, use: git commit --no-verify"
      exit 1
    fi
  done
done

# 2. Scan staged file contents for high-entropy secrets / common key patterns
SECRET_PATTERNS=(
  'AKIA[0-9A-Z]{16}'                         # AWS Access Key
  'sk-[a-zA-Z0-9]{20,}'                      # OpenAI / Stripe secret key
  'ghp_[a-zA-Z0-9]{36}'                      # GitHub PAT
  'gho_[a-zA-Z0-9]{36}'                      # GitHub OAuth token
  'xox[bpoas]-[a-zA-Z0-9-]+'                 # Slack token
  'AIza[0-9A-Za-z_-]{35}'                    # Google API key
  'SG\.[a-zA-Z0-9_-]{22}\.[a-zA-Z0-9_-]{43}' # SendGrid
  'password\s*[:=]\s*["\x27][^"\x27]{8,}'    # Inline passwords
)

for file in $STAGED_FILES; do
  # Skip binary files
  if file "$file" | grep -q "binary"; then
    continue
  fi
  if [ -f "$file" ]; then
    DIFF_CONTENT=$(git diff --cached -- "$file")
    for pattern in "${SECRET_PATTERNS[@]}"; do
      if echo "$DIFF_CONTENT" | grep -qE "$pattern"; then
        echo -e "${RED}POTENTIAL SECRET DETECTED${NC} in '$file'"
        echo "Pattern: $pattern"
        echo "If this is a false positive, use: git commit --no-verify"
        exit 1
      fi
    done
  fi
done

echo "✓ Pre-commit secret scan passed"
