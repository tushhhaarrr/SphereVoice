{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      1,
      "always",
      [
        "backend",
        "frontend",
        "infra",
        "pipeline",
        "auth",
        "agents",
        "calls",
        "providers",
        "kb",
        "analytics",
        "webhooks",
        "phone",
        "live",
        "settings",
        "shared",
        "deps",
        "ci"
      ]
    ],
    "subject-case": [2, "always", "lower-case"],
    "subject-max-length": [2, "always", 72],
    "body-max-line-length": [1, "always", 100]
  }
}
